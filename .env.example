# Backend (copy to backend/.env)
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=talentscope
JWT_SECRET_KEY=change-this-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
ADMIN_BOOTSTRAP_KEY=bootstrap-admin-once
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
ADZUNA_COUNTRY=us
ADZUNA_RESULTS_PER_PAGE=50
ADZUNA_PAGES_PER_SYNC=2
SYNC_KEYWORDS=software engineer,data analyst,devops engineer,product manager
SYNC_INTERVAL_MINUTES=180
SPACY_MODEL=en_core_web_sm
CACHE_TTL_SECONDS=300
CORS_ORIGINS=http://localhost:5173

# Frontend (copy to frontend/.env)
VITE_API_BASE_URL=http://localhost:8000/api/v1

